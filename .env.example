# Application
NODE_ENV=development

# Backend
PORT=3000

# Database (local PostgreSQL)
# If your local PostgreSQL uses peer trust auth, this can be:
# DATABASE_URL=postgres://localhost:5432/ai_novel
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_novel

# AI Provider defaults. You can also configure these in the app settings page.
AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-xxx
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=70
