{
  "name": "ai-novel",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm run -r --parallel dev",
    "dev:web": "pnpm --filter @ai-novel/web dev",
    "dev:api": "pnpm --filter @ai-novel/api dev",
    "build": "pnpm run -r build",
    "lint": "eslint . --cache --concurrency=auto",
    "lint:fix": "eslint . --fix --cache --concurrency=auto",
    "test": "pnpm run -r test",
    "check": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "db:generate": "pnpm --filter @ai-novel/api db:generate",
    "db:migrate": "pnpm --filter @ai-novel/api db:migrate",
    "db:studio": "pnpm --filter @ai-novel/api db:studio",
    "typecheck": "pnpm run -r typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@unocss/eslint-plugin": "catalog:dev",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "lint-staged": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "typescript": "catalog:dev"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "onlyBuiltDependencies": [
    "better-sqlite3",
    "esbuild",
    "simple-git-hooks"
  ]
}
